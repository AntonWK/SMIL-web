---
import WidgetWrapper from "./WidgetWrapper.astro";
import Headline from "@/components/ui/Headline.astro";

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  title?: string;
  subtitle?: string;
  images: {
    src: ImageMetadata;
    alt: string;
  }[];
  isDark?: boolean;
  bg?: string;
  id?: string;
}

const {
  title = await Astro.slots.render("title"),
  subtitle = await Astro.slots.render("subtitle"),
  images = [],
  isDark = false,
  bg = await Astro.slots.render("bg"),
  id,
} = Astro.props;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  bg={bg}
  containerClass="px-0 overflow-x-hidden pb-0 md:pb-0"
>
  <Headline
    title={title}
    subtitle={subtitle}
    classes={{
      container: "mb-0",
      title: "text-4xl md:text-5xl font-bold tracking-tighter mb-4",
      subtitle: "text-xl md:text-2xl text-muted-foreground mb-2",
    }}
  />
</WidgetWrapper>

<section id={id} class="w-full overflow-x-hidden">
  <div class="marquee">
    <div class="marquee_content scroll">
      {
        images.map((image) => (
          <div class="relative max-w-xl shrink-0 transition-transform duration-300 hover:scale-105 hover:z-10 cursor-pointer hover:shadow-xl">
            <Image
              src={image.src}
              alt={image.alt}
              class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg"
            />
          </div>
        ))
      }
    </div>

    <div class="marquee_content scroll" aria-hidden="true">
      {
        images.map((image) => (
          <div class="relative max-w-xl shrink-0 transition-transform duration-300 hover:scale-105 hover:z-10 cursor-pointer hover:shadow-2xl">
            <Image
              src={image.src}
              alt={image.alt}
              class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .marquee {
    /* margin-top: 40px; */
    display: flex;
    gap: 0.5rem;
    overflow-x: hidden;
    position: relative;
    padding-top: 10px;
    padding-bottom: 60px;
  }

  .marquee_content {
    flex-shrink: 0;
    display: flex;
    /* justify-content: space-around; */
    align-items: center;
    min-width: 100%;
    gap: 0.5rem;
    position: relative;
  }

  .marquee_content:hover {
    z-index: 10;
  }

  .marquee:hover .scroll {
    animation-play-state: paused;
  }

  .scroll {
    animation: scroll 15s linear infinite; /* tid det tar för bilden att passera */
    will-change: transform; /* Ger en mjukare upplevelse och minskar lagg */
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% - 0.5rem));
    }
  }
</style>
