---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import openSourceImg from "@/assets/images/open-source.png";
import Content2 from "@/components/widgets/Content2.astro";
import Github from "@/components/widgets/Github.astro";
import Integrations from "@/components/widgets/Integrations.astro";
const metadata = {
  title: `${siteConfig.name} — Nätverk och företagsutveckling i Linköping`,
  description: siteConfig.description,
  ignoreTitleTemplate: true,
};

import { Image } from "astro:assets";
import smilBanner from "@/assets/images/smil-banner-utvp.png";
import smilLogo from "@/assets/smil-logga.png";
import smil40 from "@/assets/smil-40.png";
---

<BaseLayout {metadata}>
  <Hero
    title={`VÄLKOMMEN TILL SMIL <br class="hidden md:block" /> <span class="bg-linear-to-r bg-primary bg-clip-text text-transparent">Linköpings nätverk för företagsledare och entreprenörer</span>`}
    tagline=""
    description={`${siteConfig.description}`}
    actions={[
      {
        text: "Om SMIL",
        href: "/om-smil",
        variant: "secondary",
        icon: "lucide:smile",
        ariaLabel: "Om SMIL - Information om oss",
      },
      {
        text: "Bli medlem idag!",
        href: "/bli-medlem",
        variant: "primary",
        icon: "lucide:user-plus",
        ariaLabel: "Bli medlem idag! - Länk till medlemskapsformulär",
      },
    ]}
  />
  <Features
    tagline="Väx med SMIL"
    title="Vårt erbjudande"
    subtitle="SMIL erbjuder flertal möjligheter för företag att utväcklas oavsätt storlek!"
    features={[
      {
        title: "Evenemang",
        description:
          "Base configuration for Meta tags, Open Graph, and Sitemap generation.",
        icon: "lucide:calendar-days",
        iconClass: "bg-primary/10 text-primary",
      },
      {
        title: "Utbildningsprogram",
        description: "Lightweight structure for fast load times.",
        icon: "lucide:book-open",
        iconClass: "bg-primary/10 text-primary",
      },
      {
        title: "Nätvärkande med liksinta företagsledare",
        description:
          "Integrated configuration with the latest version of Tailwind CSS.",
        icon: "lucide:network",
        iconClass: "bg-primary/10 text-primary",
      },
    ]}
  />
  <Content2 image={smil40} imageAlt="Development">
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        AV ENTREPRENÖRER, <br />
        FÖR ENTREPRENÖRER
      </h3>

      <div class="w-24 h-1 bg-primary rounded-full mb-6"></div>

      <p class="text-lg text-muted-foreground">
        <p>
          <p class="text-lg text-muted-foreground mb-4">
            Vi tror på <strong>låga trösklar</strong> och <strong
              >högt i tak</strong
            >.
          </p>

          <p class="text-lg text-muted-foreground mb-4">
            Vi tror att <strong>möten</strong> med andra människor <strong
              >berikar</strong
            > oss.
          </p>

          <p class="text-lg text-muted-foreground">
            Vi tror att <strong>tillsammans</strong> kan vi <strong
              >bli klokare</strong
            > än vad vi kan åstadkomma själva.
          </p>
        </p>
      </p>
    </Fragment>
  </Content2>

  <Integrations
    title="Trusted by top companies"
    subtitle="Our platform integrates seamlessly with your favorite tools."
    tagline="Integrations"
    integrations={[
      { name: "Astro", icon: "tabler:brand-astro", url: "#" },
      { name: "Tailwind CSS", icon: "tabler:brand-tailwind", url: "#" },
      { name: "Vercel", icon: "tabler:brand-vercel", url: "#" },
      { name: "GitHub", icon: "tabler:brand-github", url: "#" },
    ]}
  />
  <Github
    title="Don't forget to star us!"
    subtitle="Support this template and keep the project alive. Your stars help us continue improving and adding new features."
    tagline="Open Source"
    icon="lucide:github"
    actions={[
      {
        text: "Star on GitHub",
        href: "https://github.com/devgelo-labs/astro-starter-pro",
        variant: "primary",
        icon: "lucide:star",
      },
      {
        text: "Fork Repository",
        href: "https://github.com/devgelo-labs/astro-starter-pro/fork",
        variant: "secondary",
        icon: "lucide:git-fork",
      },
    ]}
  />
</BaseLayout>
