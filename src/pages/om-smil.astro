---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import SplitContent from "@/components/widgets/SplitContent.astro";
import People from "@/components/widgets/People.astro";
import aboutImage from "@/assets/smil-40.png";
import PageTitle from "@/components/widgets/PageTitle.astro";
import WidgetWrapper from "@/components/widgets/WidgetWrapper.astro";

import aseelImage from "@/assets/styrelsen/aseel-berglund.jpg";
import bjornImage from "@/assets/styrelsen/bjorn.png";
import saraImage from "@/assets/styrelsen/sara.jpg";
import peterImage from "@/assets/styrelsen/peter.jpg";
import andersImage from "@/assets/styrelsen/Anders.jpg";
import lottaImage from "@/assets/styrelsen/lotta.png";
import mikaelImage from "@/assets/styrelsen/mikael-hult.jpg";

const metadata = {
  title: "About us",
};

const people = [
  {
    name: "Aseel Berglund",
    role: "Ordförande",
    company: "Linköping University och Liopep AB",
    mail: "aseel.berglund@liu.se",
    image: aseelImage,
    imageUrl: aseelImage.src,
  },
  {
    name: "Björn Elenfors",
    company: "Benalto AB",
    mail: "bjorn@elenfors.com",
    image: bjornImage,
    imageUrl: bjornImage.src,
  },
  {
    name: "Sara Ådahl-Aggebäck",
    company: "Embersvik Consulting AB",
    mail: "sara@embersvikconsulting.se",
    image: saraImage,
    imageUrl: saraImage.src,
  },
  {
    name: "Peter Lindgren",
    company: "Visiarc",
    mail: "peter@visiarc.com",
    image: peterImage,
    imageUrl: peterImage.src,
  },
  {
    name: "Anders Petersson",
    company: "Sparv Embedded",
    mail: "anders@sparvembedded.com",
    image: andersImage,
    imageUrl: andersImage.src,
  },
  {
    name: "Ann-Charlotte Johannesson",
    company: "NXT Learning, CEI",
    mail: "lotta.m.johannesson@gmail.com",
    image: lottaImage,
    imageUrl: lottaImage.src,
  },
  {
    name: "Mikael Hult",
    role: "Suppleant",
    company: "GI Lift",
    mail: "mikael.hult@milt.se ",
    image: mikaelImage,
    imageUrl: mikaelImage.src,
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <PageTitle title="Vad är SMIL?" />
  <WidgetWrapper>
    <hr class="border-gray-200 dark:border-slate-800 mb-8" />
    <SplitContent
      description={[
        "SMIL är nätverket för Linköpings entreprenörer och företagsledare. Här får du tillgång till utbildningar, nätverksträffar och seminarier inom områden som berör och utvecklar ditt företagande. Du får också möjlighet att etablera nya affärskontakter – både lokala och globala – via våra nätverksträffar, aktiviteter och workshops.",
        "Tillsammans kan vi skapa en av Europas bästa och mest kreativa entreprenörs- och innovationsmiljöer.",
      ]}
      actions={[
        {
          text: "Bli medlem",
          href: "/bli-medlem",
          variant: "primary",
          icon: "lucide:user-plus",
        },
      ]}
      columnRatio="2/3-1/3"
      items={[
        {
          title: "Kontaktuppgifter",
          icon:"lucide:mail",
          description: ["Mikael Hult",
          "+46 (0)70 564 25 45",
          ],
          mail:"info@smil.se",
        },
        {
          title: "Faktureringsadress",
          icon: "lucide:receipt",
          mail: "faktura@smil.se"
        },
        {
          title:"Utdelningsadress",
          icon:"lucide:map-pin",
          description : "Rådjursvägen 7, 587 31 Linköping"
        }
      ]}
    />
    <hr class="border-gray-200 dark:border-slate-800 mb-8" />

    <People
      items={people}
      columns={2}
      tagline="Styrelsen"
      title="SMIL-teamet"
    />
  </WidgetWrapper>
</BaseLayout>
